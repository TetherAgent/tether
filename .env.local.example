# Copy to .env.local for local debugging:
#   cp .env.local.example .env.local
#
# .env.local is intentionally ignored by git. Fill secrets locally or copy the
# shared development env.sh into .env.local when you want to use the shared dev DB.

# Server
export EGG_SERVER_ENV=local
export TETHER_SERVER_HOST=127.0.0.1
export TETHER_SERVER_PORT=4800
export TETHER_SERVER_JWT_SECRET=local-dev-jwt-secret-change-me
export TETHER_SERVER_WEB_ORIGIN=http://127.0.0.1:4790,http://localhost:4790

# MySQL. Leave blank here; use your shared dev RDS values in .env.local.
export TETHER_SERVER_MYSQL_HOST=
export TETHER_SERVER_MYSQL_PORT=3306
export TETHER_SERVER_MYSQL_USER=
export TETHER_SERVER_MYSQL_PASSWORD=
export TETHER_SERVER_MYSQL_DATABASE=

# Redis is optional unless explicitly enabled.
export TETHER_SERVER_ENABLE_REDIS=0
export TETHER_SERVER_REDIS_HOST=127.0.0.1
export TETHER_SERVER_REDIS_PORT=6379

# Relay
export TETHER_RELAY_HOST=127.0.0.1
export TETHER_RELAY_PORT=4889
export TETHER_RELAY_SECRET=local-dev-relay-secret-change-me
export TETHER_SERVER_URL=http://127.0.0.1:4800
export TETHER_RUNTIME_SYNC_SECRET="${TETHER_RUNTIME_SYNC_SECRET:-$TETHER_RELAY_SECRET}"

# Web
export TETHER_WEB_PORT=4790
export TETHER_WEB_SERVER_API_URL=http://127.0.0.1:4800
export TETHER_WEB_RELAY_WS_URL=ws://127.0.0.1:4889

# Isolated local Gateway. This avoids overwriting ~/.tether.
export TETHER_GATEWAY_PROFILE=relay
export TETHER_GATEWAY_HOST=127.0.0.1
export TETHER_GATEWAY_PORT=4799
export TETHER_RELAY_URL=ws://127.0.0.1:4889
export TETHER_DEV_HOME=.tether-dev-home
