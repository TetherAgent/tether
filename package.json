{
  "name": "tether",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "tether": "./bin/tether"
  },
  "scripts": {
    "typecheck": "pnpm -r --if-present run typecheck",
    "dev:web": "pnpm --filter @tether/web dev",
    "dev:admin": "pnpm --filter @tether/admin-web dev",
    "dev:server": "if [ -f env.sh ]; then . env.sh; elif [ -f /data/env/tether.sh ]; then . /data/env/tether.sh; fi; EGG_SERVER_ENV=local pnpm --filter @tether/server dev",
    "build:web": "pnpm --filter @tether/web build",
    "build:admin": "pnpm --filter @tether/admin-web build",
    "build:server": "pnpm --filter @tether/server build",
    "build:relay": "pnpm --filter @tether/relay build",
    "start:server": "if [ -f /data/env/tether.sh ]; then . /data/env/tether.sh; elif [ -f env.sh ]; then . env.sh; fi; pnpm --filter @tether/server start",
    "stop:server": "pnpm --filter @tether/server stop",
    "start:relay": "pm2 start ecosystem.config.cjs",
    "reload:relay": "pm2 reload tether-relay",
    "stop:relay": "pm2 stop tether-relay",
    "relay": "node apps/relay/dist/main.js",
    "dev:codex": "tsx apps/cli/src/main.ts codex --host 0.0.0.0",
    "dev:relay": "[ -f env.sh ] && . env.sh; tsx apps/relay/src/main.ts",
    "test": "pnpm -r --if-present run test",
    "tether": "tsx apps/cli/src/main.ts"
  },
  "dependencies": {
    "@tether/cli": "workspace:*",
    "@tether/gateway": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "node-pty"
    ]
  }
}
